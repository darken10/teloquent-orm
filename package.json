{
  "name": "teloquent",
  "version": "3.0.0",
  "description": "Un ORM TypeScript Active Record inspiré de Laravel Eloquent.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "dev": "tsc -w -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "example": "tsx examples/basic.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "orm",
    "eloquent",
    "active-record",
    "typescript",
    "sqlite",
    "mysql",
    "postgres",
    "query-builder"
  ],
  "author": "AfricaSys",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": { "optional": true },
    "mysql2": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
